# PatchPilot v2 environment variables
# Copy this file to .env and fill in real values.

# === TokenRouter (model gateway) ===
# Get key: https://www.tokenrouter.com (hackathon credits link from sponsor)
TOKENROUTER_API_KEY=tr_...
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1
PATCHPILOT_FREE_MODEL=qwen/qwen3-coder-next
PATCHPILOT_CHEAP_MODEL=qwen/qwen3-coder-next
PATCHPILOT_PRO_MODEL=qwen/qwen3-coder-next

# === Qwen Cloud (alternative direct provider) ===
# Get credits: https://tinyurl.com/qwencloudcredits
# Optional — used only if you bypass TokenRouter for specific models
QWEN_API_KEY=qwen_...
QWEN_BASE_URL=https://api.qwencloud.com/v1

# === GitHub (PR creation + webhook auth) ===
# Personal access token with `repo` scope
GITHUB_TOKEN=ghp_...
# Webhook secret (any random string; configured in GitHub repo settings)
GITHUB_WEBHOOK_SECRET=changeme

# === AgentField control plane ===
AGENTFIELD_SERVER_URL=http://localhost:8080
# Optional: PostgreSQL for durable queue + memory (required for production)
DATABASE_URL=postgresql://af:af@postgres:5432/agentfield

# === PatchPilot policy ===
# Default budget per repair run (USD)
PATCHPILOT_BUDGET_USD=0.50
# Default verification command (overrideable per-repo)
PATCHPILOT_VERIFY_COMMAND=npm test
